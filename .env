
# ─────────────────────────────────────────────────────────────────────────────
# Registration + login flow
#
# All values are optional: with none set, the app runs as a self-contained demo
# (World ID scan + wallet are simulated). Set them to switch to the real SDKs.
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# World ID (World 3.0 / IDKit) — from https://developer.world.org
# Create a "Cloud" app + an "Incognito Action" matching NEXT_PUBLIC_WLD_ACTION_REGISTER.
NEXT_PUBLIC_WLD_APP_ID=app_5e22b7aeace5c59e5217ad7e6c928324
NEXT_PUBLIC_WLD_RP_ID=rp_125083d98f54ac84
NEXT_PUBLIC_WLD_ACTION_REGISTER=register-trialland
WORLD_RP_SIGNING_KEY=0xaa44bfd3f364333d6428ef46fb679e6aa4ee07d308c6798e7505441358c7bd73
NEXT_PUBLIC_CONTRACT_CHAIN_ID=11155111

# Dynamic (embedded wallet + login) — environment id from https://app.dynamic.xyz
# Dashboard → Developers → API → Environment ID
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=68b769cb-2b79-416c-8040-6afc6939ecbe