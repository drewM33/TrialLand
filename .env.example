# ─────────────────────────────────────────────────────────────────────────────
# Registration + login flow
#
# All values are optional: with none set, the app runs as a self-contained demo
# (World ID scan + wallet are simulated). Set them to switch to the real SDKs.
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# World ID (IDKit 4.x) — from https://developer.world.org
# Enable World ID 4.0 on your app, then copy app_id, rp_id, signing key, and action.
NEXT_PUBLIC_WLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WLD_RP_ID=rp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WLD_ACTION_REGISTER=register-trialland
# Server-only. Never commit the real key or expose it to the client.
WLD_SECURE_SIGNING_KEY=

# Dynamic (embedded wallet + login) — environment id from https://app.dynamic.xyz
# Dashboard → Developers → API → Environment ID
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
